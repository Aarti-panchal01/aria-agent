# Get your free Groq API key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get your free Tavily API key at app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — a GitHub personal access token raises the GitHub source's rate
# limit (public repo search works without one). https://github.com/settings/tokens
# GITHUB_TOKEN=your_github_token_here

# Sources with no key required and always available: arXiv, Wikipedia.

