# Streamlit Cloud secrets template.
#
# On Streamlit Cloud: App → Settings → Secrets, paste the keys below (with real
# values). Locally: copy this file to .streamlit/secrets.toml (gitignored) or use
# a .env file — ARIA reads keys from os.environ, and Streamlit injects st.secrets
# into the environment on Cloud.

GROQ_API_KEY = "your_groq_api_key_here"       # https://console.groq.com
TAVILY_API_KEY = "your_tavily_api_key_here"   # https://app.tavily.com

# Optional — raises GitHub source rate limits (Phase 5 multi-source research).
# GITHUB_TOKEN = "your_github_pat_here"
